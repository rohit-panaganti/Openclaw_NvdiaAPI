{
  "bindings": [
    {
      "match": {
        "channel": "telegram",
        "peer": {
          "kind": "direct",
          "id": "YOUR_TELEGRAM_USER_ID"
        }
      },
      "agentId": "main"
    }
  ],
  "agents": {
    "defaults": {
      "model": {
        "primary": "nvidia/minimaxai/minimax-m2.7"
      },
      "models": {}
    }
  },
  "models": {
    "providers": {
      "nvidia": {
        "baseUrl": "https://integrate.api.nvidia.com/v1",
        "apiKey": "YOUR_NVIDIA_API_KEY",
        "api": "openai-completions",
        "models": [
          {
            "id": "minimaxai/minimax-m2.7",
            "name": "Minimax M2.7"
          }
        ]
      }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "YOUR_GATEWAY_AUTH_TOKEN"
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      },
      "nvidia": {
        "enabled": true
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "botToken": "YOUR_TELEGRAM_BOT_TOKEN",
      "dmPolicy": "allowlist",
      "allowFrom": [
        YOUR_TELEGRAM_USER_ID_NUMBER
      ]
    }
  }
}
